# .htaccess for React Router
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# Enable gzip/brotli compression for text-based assets
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Hashed assets (in /assets/) are immutable — cache indefinitely
<FilesMatch "\.(jpg|jpeg|png|gif|svg|js|css|otf|woff2|woff|eot|ttf)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
</FilesMatch>

# HTML files change on each deploy — short cache + must-revalidate
<FilesMatch "\.(html)$">
    Header set Cache-Control "max-age=3600, public, must-revalidate"
</FilesMatch>
